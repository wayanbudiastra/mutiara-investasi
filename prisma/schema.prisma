// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  calculations Calculation[]
  watchlist Watchlist[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model Calculation {
  id                      String   @id @default(cuid())
  userId                  String
  stockSymbol             String
  quantity                Int
  buyPricePerShare        Float
  buyPrice                Float
  sellPricePerShare       Float?
  sellPrice               Float?
  feeBuyPercentage        Float    @default(0.19)
  feeSellPercentage       Float    @default(0.29)
  targetProfitPercentage  Float?
  cutLossPercentage       Float?
  
  // Calculated values
  modal                   Float
  feeBuyAmount            Float    @default(0)
  feeSellAmount           Float    @default(0)
  totalFees               Float    @default(0)
  profitBruto             Float?
  profitNetto             Float?
  returnPercentage        Float?
  
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("calculations")
}

model Watchlist {
  id          String @id @default(cuid())
  userId      String
  stockSymbol String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stockSymbol])
  @@map("watchlist")
}